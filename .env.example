# Copy this file to ".env" (or set these as real environment variables) and fill in your values.

# Required for live drone extraction. Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The model used to read Telegram posts and extract structured sightings.
# Defaults to the free stealth model requested for this project.
OPENROUTER_MODEL=openrouter/owl-alpha

# Public Telegram channel to monitor (username without @).
TELEGRAM_CHANNEL=radarrussiia

# How often to poll the channel, in seconds.
POLL_INTERVAL_SECONDS=120

# Set to 1 to start in demo mode (uses bundled sample data, no network/API key needed).
DDX_DEMO=0
