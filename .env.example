# Copy this file to ".env" (or set these as real environment variables) and fill in your values.
# Every value here is optional — the app ships with sensible defaults and a
# Settings panel, so you usually don't need a .env at all.

# ---- AI backend -------------------------------------------------------------
# "ollama" (default) runs everything locally — no API key, no rate limits.
# "openrouter" uses the cloud instead.
DDX_AI_BACKEND=ollama

# Local Ollama server + model. Install the model once with:
#   ollama pull translategemma:12b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=translategemma:12b

# Second model pass that re-checks every extraction against the post text for
# accuracy (1 = on, 0 = off).
DDX_VERIFY=1

# ---- OpenRouter (only when DDX_AI_BACKEND=openrouter) ------------------------
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ---- Channels & collection --------------------------------------------------
# Public Telegram channels to monitor (usernames without @, comma-separated).
TELEGRAM_CHANNELS=radarrussiia,kpszsu,lpr1_treugolnik

# On startup the app pages back through this many hours of history and draws it
# as flight tracks. Also the length of the timeline scrubber.
DDX_BACKFILL_HOURS=48

# How often to poll for new posts, in seconds.
POLL_INTERVAL_SECONDS=120

# Set to 1 to start in demo mode (bundled sample data, no network/AI needed).
DDX_DEMO=0
